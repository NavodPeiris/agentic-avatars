{
  "name": "agentic-avatars",
  "version": "0.1.5",
  "description": "Zero-Infrastructure Lip-Synced 3D avatar components for AI voice agents. Built with React Three Fiber and AI providers.",
  
  "author": "Navod Peiris",
  "license": "MIT",

  "repository": {
    "type": "git",
    "url": "https://github.com/NavodPeiris/agentic-avatars.git"
  },
  "homepage": "https://github.com/NavodPeiris/agentic-avatars#readme",
  "bugs": {
    "url": "https://github.com/NavodPeiris/agentic-avatars/issues"
  },

  "type": "module",

  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./openai": {
      "types": "./dist/openai.d.ts",
      "import": "./dist/openai.mjs",
      "require": "./dist/openai.cjs"
    },
    "./vapi": {
      "types": "./dist/vapi.d.ts",
      "import": "./dist/vapi.mjs",
      "require": "./dist/vapi.cjs"
    },
    "./elevenlabs": {
      "types": "./dist/elevenlabs.d.ts",
      "import": "./dist/elevenlabs.mjs",
      "require": "./dist/elevenlabs.cjs"
    },
    "./livekit": {
      "types": "./dist/livekit.d.ts",
      "import": "./dist/livekit.mjs",
      "require": "./dist/livekit.cjs"
    },
    "./deepgram": {
      "types": "./dist/deepgram.d.ts",
      "import": "./dist/deepgram.mjs",
      "require": "./dist/deepgram.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },

  "files": [
    "dist"
  ],

  "sideEffects": [
    "*.css"
  ],

  "keywords": [
    "ai",
    "avatars",
    "3d",
    "voice-ai",
    "lip-sync",
    "react",
    "threejs",
    "react-three-fiber",
    "ai-agents",
    "voice-agents",
    "virtual-assistant",
    "speech-to-speech",
    "real-time-avatar"
  ],

  "engines": {
    "node": ">=18"
  },

  "scripts": {
    "build": "tsup && tailwindcss -i src/styles.css -o dist/styles.css --minify",
    "prepublishOnly": "npm run build"
  },

  "peerDependencies": {
    "@react-three/drei": ">=10",
    "@react-three/fiber": ">=9",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.160",
    "@deepgram/sdk": "^5.0.0",
    "@elevenlabs/react": "^1.0.2",
    "@vapi-ai/web": "^2.5.2",
    "livekit-client": "2.16.1"
  },

  "peerDependenciesMeta": {
    "@deepgram/sdk": { "optional": true },
    "@elevenlabs/react": { "optional": true },
    "@vapi-ai/web": { "optional": true },
    "livekit-client": { "optional": true }
  },

  "dependencies": {
    "three-stdlib": "^2.0.0",
    "uuid": "^9.0.0",
    "wawa-lipsync": "*"
  },

  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/three": "^0.165.0",
    "@types/uuid": "^9.0.0",
    "tailwindcss": "^3.0.0",
    "tsup": "^8",
    "typescript": "^5.0.0",
    "@deepgram/sdk": "^5.0.0",
    "@elevenlabs/react": "^1.0.2",
    "@vapi-ai/web": "^2.5.2",
    "livekit-client": "2.16.1"
  },

  "overrides": {
    "livekit-client": "2.16.1"
  }
}