{
  "name": "agentic-avatars",
  "version": "0.1.0",
  "description": "Zero-Infrastructure Lip-Synced 3D avatar components for AI voice agents. this library is built with React Three Fiber and AI providers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsc && tailwindcss -i src/styles.css -o dist/styles.css --minify"
  },
  "peerDependencies": {
    "@react-three/drei": ">=10",
    "@react-three/fiber": ">=9",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.160",
    "@deepgram/sdk": "^3.13.0",
    "@elevenlabs/react": "^1.0.2",
    "@openai/agents": "^0.0.11",
    "@vapi-ai/web": "^2.5.2",
    "livekit-client": "2.16.1"
  },
  "peerDependenciesMeta": {
    "@deepgram/sdk": { "optional": true },
    "@elevenlabs/react": { "optional": true },
    "@openai/agents": { "optional": true },
    "@vapi-ai/web": { "optional": true },
    "livekit-client": { "optional": true }
  },
  "dependencies": {
    "three-stdlib": "^2",
    "uuid": "^9",
    "wawa-lipsync": "*"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/three": "^0.165",
    "@types/uuid": "^9",
    "tailwindcss": "^3",
    "typescript": "^5"
  },
  "overrides": {
    "livekit-client": "2.16.1"
  }
}
